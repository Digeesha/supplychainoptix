    "def get_db_connection() -> create_engine:\n",
    "    \"\"\"Establish PostgreSQL connection using SQLAlchemy.\"\"\"\n",
    "    # In production, use environment variables\n",
    "    DB_CONFIG = {\n",
    "        'user': 'supplychain_user',\n",
    "        'password': 'secure_password',\n",
    "        'host': 'localhost',\n",
    "        'port': 5432,\n",
    "        'database': 'supply_chain_db'\n",
    "    }\n",
    "    \n",
    "    connection_string = (\n",
    "        f\"postgresql://{DB_CONFIG['user']}:{DB_CONFIG['password']}\"\n",
    "        f\"@{DB_CONFIG['host']}:{DB_CONFIG['port']}/{DB_CONFIG['database']}\"\n",
    "    )\n",
    "    \n",
    "    return create_engine(connection_string)\n",
    "\n",
    "\n",
    "def load_shipment_data(engine, days_back: int = 180) -> pd.DataFrame:\n",
    "    \"\"\"Load shipment data from PostgreSQL with date filtering.\"\"\"\n",
    "    query = f\"\"\"\n",
    "    SELECT \n",
    "        s.shipment_id,\n",
    "        s.order_date,\n",
    "        s.expected_delivery_date,\n",
    "        s.actual_delivery_date,\n",
    "        s.origin_port,\n",
    "        s.destination_port,\n",
    "        s.carrier_id,\n",
    "        s.route_id,\n",
    "        s.shipment_value_usd,\n",
    "        s.weight_kg,\n",
    "        s.volume_m3,\n",
    "        s.is_delayed,\n",
    "        s.delay_days,\n",
    "        c.carrier_name,\n",
    "        c.carrier_reliability_score,\n",
    "        r.route_name,\n",
    "        r.avg_transit_days,\n",
    "        r.risk_level\n",
    "    FROM shipments s\n",
    "    LEFT JOIN carriers c ON s.carrier_id = c.carrier_id\n",
    "    LEFT JOIN routes r ON s.route_id = r.route_id\n",
    "    WHERE s.order_date >= CURRENT_DATE - INTERVAL '{days_back} days'\n",
    "    ORDER BY s.order_date DESC\n",
    "    \"\"\"\n",
    "    \n",
    "    df = pd.read_sql(query, engine)\n",
    "    \n",
    "    # Convert date columns\n",
    "    date_cols = ['order_date', 'expected_delivery_date', 'actual_delivery_date']\n",
    "    for col in date_cols:\n",
    "        df[col] = pd.to_datetime(df[col])\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def load_geopolitical_events(engine, days_back: int = 180) -> pd.DataFrame:\n",
    "    \"\"\"Load geopolitical events that may impact supply chain.\"\"\"\n",
    "    query = f\"\"\"\n",
    "    SELECT \n",
    "        event_id,\n",
    "        event_date,\n",
    "        event_type,\n",
    "        affected_region,\n",
    "        severity_score,\n",
    "        impact_category,\n",
    "        description\n",
    "    FROM geopolitical_events\n",
    "    WHERE event_date >= CURRENT_DATE - INTERVAL '{days_back} days'\n",
    "    ORDER BY event_date DESC\n",
    "    \"\"\"\n",
    "    \n",
    "    df = pd.read_sql(query, engine)\n",
    "    df['event_date'] = pd.to_datetime(df['event_date'])\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def load_inventory_data(engine) -> pd.DataFrame:\n",
    "    \"\"\"Load current and historical inventory levels.\"\"\"\n",
    "    query = \"\"\"\n",
    "    SELECT \n",
    "        i.inventory_id,\n",
    "        i.snapshot_date,\n",
    "        i.sku,\n",
    "        i.warehouse_id,\n",
    "        i.current_stock,\n",
    "        i.min_stock_level,\n",
    "        i.max_stock_level,\n",
    "        i.reorder_point,\n",
    "        i.avg_daily_demand,\n",
    "        i.lead_time_days,\n",
    "        p.product_category,\n",
    "        p.unit_cost_usd,\n",
    "        w.warehouse_name,\n",
    "        w.location_country\n",
    "    FROM inventory_snapshots i\n",
    "    LEFT JOIN products p ON i.sku = p.sku\n",
    "    LEFT JOIN warehouses w ON i.warehouse_id = w.warehouse_id\n",
    "    WHERE i.snapshot_date >= CURRENT_DATE - INTERVAL '90 days'\n",
    "    ORDER BY i.snapshot_date DESC\n",
    "    \"\"\"\n",
    "    \n",
    "    df = pd.read_sql(query, engine)\n",
    "    df['snapshot_date'] = pd.to_datetime(df['snapshot_date'])\n",
    "    \n",
    "    return df"
   ]
  },
